# Mino environment variables
# Copy this to your systemd EnvironmentFile or export before running.

# --- Required ---
MINO_API_KEY=sk-your-key-here
MINO_BASE_URL=https://api.openai.com/v1
MINO_MODEL=gpt-4o-mini

# --- Optional ---
MINO_HOME=~/.mino
MINO_SMALL_MODEL=gpt-4o-mini
MINO_DASHBOARD_PORT=7777
MINO_DASHBOARD_HOST=
MINO_MAX_ITERATIONS=25
MINO_MAX_TOKENS=4096
MINO_CONTEXT_CHARS=100000
MINO_CONNECT_EVERY=0
MINO_MIN_SIMILARITY=0.45

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Free image generation (Pollinations.ai, no key needed) ---
# HF_TOKEN=  (only needed for HuggingFace FLUX, not required for Pollinations)

# --- Web search ---
TAVILY_API_KEY=

# --- OpenRouter (embeddings, fallback models) ---
MINO_OPENROUTER_KEY=
MINO_EMBED_MODEL=openai/text-embedding-3-large
